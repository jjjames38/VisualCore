# ═══════════════════════════════════════════════════════════════
#  RenderForge + VisualCore + VoiceCore — Environment Variables
# ═══════════════════════════════════════════════════════════════
#  Copy to .env and fill in values.
#  Usage: docker compose -f docker/docker-compose.gpu.yml --env-file .env up -d
# ═══════════════════════════════════════════════════════════════

# ─── RenderForge Core ───
PORT=3000
REDIS_URL=redis://redis:6379
CHROMIUM_WS=ws://chromium:3000
STORAGE_DRIVER=local
STORAGE_PATH=/data
DB_DRIVER=sqlite
SQLITE_PATH=/data/db.sqlite
# DB_DRIVER=pg
# DATABASE_URL=postgresql://user:pass@host:5432/renderforge

# ─── Authentication ───
AUTH_ENABLED=true
API_KEYS=rf_your_api_key_here
# JWT_SECRET=your_jwt_secret

# ─── GPU Providers (Local) ───
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188
COMFYUI_PROTOCOL=ws

HUNYUAN_HOST=hunyuan
HUNYUAN_PORT=8190
HUNYUAN_ENABLE_STEP_DISTILL=true
HUNYUAN_DEFAULT_STEPS=8

VOICECORE_HOST=voicecore
VOICECORE_PORT=8080

# ─── Seedance Remote (high-priority fallback) ───
# Only used for visual_priority=high scenes (~20% of video clips)
# Leave empty to disable API fallback entirely
SEEDANCE_API_KEY=
SEEDANCE_API_URL=https://api.seedance.com/v1
SEEDANCE_TIER=fast
# fast = $0.022/sec, pro = $0.247/sec

# ─── Seedream Remote (emergency image fallback) ───
# Only used when local Flux fails QC 3 times
SEEDREAM_API_KEY=
SEEDREAM_API_URL=https://api.seedream.com/v1

# ─── Quality Control ───
QC_CLIP_THRESHOLD=0.25
QC_AESTHETIC_THRESHOLD=5.0
QC_NSFW_THRESHOLD=0.3
QC_TEMPORAL_THRESHOLD=0.8
QC_MAX_RETRIES=3
QC_FALLBACK_TO_API=true

# ─── GPU Memory Manager ───
GPU_SWAP_STRATEGY=on-demand
# on-demand = swap when needed (default)
# scheduled = time-based swap schedule

GPU_DEFAULT_MODEL=flux-klein
# Model loaded at startup: flux-klein | hunyuan

GPU_FISH_SPEECH_RESIDENT=true
# Keep Fish Speech always in VRAM (~2GB)

GPU_VRAM_TOTAL_GB=24
# Your GPU's total VRAM

# ─── LoRA Presets (tier_id → filename) ───
# Place .safetensors files in the comfyui-loras volume
# Format: LORA_{TIER_ID}={filename}
LORA_T1_SPACE=space_astronomy_v1.safetensors
LORA_T2_HISTORY=history_classical_v1.safetensors
LORA_T3_SCIENCE=science_tech_v1.safetensors
LORA_T4_FINANCE=finance_business_v1.safetensors
LORA_T5_HEALTH=health_wellness_v1.safetensors
LORA_T6_NATURE=nature_wildlife_v1.safetensors
LORA_T7_CRIME=true_crime_dark_v1.safetensors
LORA_T8_EDUCATION=education_bright_v1.safetensors
LORA_T9_ENTERTAINMENT=pop_culture_v1.safetensors
LORA_THUMBNAIL=text_rendering_v1.safetensors

# ─── Real-ESRGAN ───
REALESRGAN_BIN=realesrgan-ncnn-vulkan
# Path to realesrgan binary (installed in container)

# ─── Monitoring ───
# Prometheus metrics exposed at GET /metrics
METRICS_ENABLED=true

# ─── Logging ───
LOG_LEVEL=info
# debug | info | warn | error
